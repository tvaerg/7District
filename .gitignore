# =============================================================================
# 7D Portfolio Aggregation Engine -- .gitignore
# =============================================================================

# Klientdata: pusha ALDRIG faktiska rapportfiler till Git.
# Dessa innehåller bolagens finansiella siffror och hör inte hemma i repot.
*.pdf
*.pptx
*.ppt
*.docx
*.doc
*.xlsx
*.xls
*.csv

# ...men behall PowerPoint-mallen som kravs for att kora motorn.
# Negeringen aterinkluderar allt under assets/ aven om det matchar ovan.
!assets/
!assets/**

# Genererade deckar och deras debug-dumpar (innehaller ocksa klientsiffror).
output/

# Hemligheter och miljo.
.env
.env.*
!.env.example

# Python-skrap.
venv/
.venv/
__pycache__/
*.pyc
.DS_Store